# ============================================================
# LOCAL DEVELOPMENT ENV
# - Backend/.env me copy karke local values fill karo.
# - Render production me same keys Environment tab me add karni hain.
# ============================================================

PORT=5001
NODE_ENV=development
ADMIN_PASS=Chandan@123
ADMIN_TOKEN_SECRET=change-this-long-random-secret-before-production
PUBLIC_SITE_URL=http://localhost:5001

# MySQL local setup
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=12345678
DB_NAME=portfolio
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# Email alerts
# Contact submit, review submit, aur website visit par email alert bhejne ke liye.
ALERT_EMAIL_TO=chandankumar122c@gmail.com
ALERT_ON_CONTACT=true
ALERT_ON_REVIEW=true
ALERT_ON_VISIT=true
ALERT_VISIT_THROTTLE_MINUTES=0
MAIL_USER=chandankumar122c@gmail.com
MAIL_PASS=your-gmail-app-password
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_FROM=chandankumar122c@gmail.com
MAIL_CONNECTION_TIMEOUT_MS=12000

